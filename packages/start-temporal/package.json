{
  "name": "@btravstack/start-temporal",
  "version": "0.0.0",
  "private": true,
  "description": "The btravstack start Temporal host: run demesne-wired contracts as activities, mapping domain errors to retryable / non-retryable, with determinism enforced structurally.",
  "keywords": [
    "12-factor",
    "activity",
    "contract",
    "demesne",
    "durable",
    "temporal",
    "typescript",
    "unthrown",
    "workflow"
  ],
  "homepage": "https://github.com/btravstack/start#readme",
  "bugs": {
    "url": "https://github.com/btravstack/start/issues"
  },
  "license": "MIT",
  "author": "Benoit TRAVERS <benoit.travers.fr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btravstack/start.git",
    "directory": "packages/start-temporal"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "build:docs": "typedoc",
    "check:package": "publint --strict && attw --pack .",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:types": "tsc --noEmit -p tsconfig.test-d.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test-d.json"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@btravstack/start-kernel": "workspace:*",
    "@btravstack/tsconfig": "catalog:",
    "@btravstack/typedoc": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "demesne": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typescript": "catalog:",
    "unthrown": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@btravstack/start-kernel": "workspace:^",
    "demesne": "^0.2.0",
    "unthrown": "^4.1.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=22.19"
  }
}
